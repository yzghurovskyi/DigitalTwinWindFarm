{
  "version": "2.0",
  "extensions": {
    "eventHubs": {
      "transportType": "amqpWebSockets",
      "initialOffsetOptions": {
        "type": "fromStart"
      }
    }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}

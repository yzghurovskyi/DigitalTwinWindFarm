# Simulator environment variables
# Copy this file to .env and fill in your values.

# Backend HTTP ingest endpoint (used as fallback when IoT Hub is not configured)
BACKEND_INGEST_URL=http://localhost:8080/ingest

# Polling interval between telemetry batches in milliseconds (default: 1500)
POLL_MS=1500

# ── IoT Hub device connections (optional) ────────────────────────────────
# When set, the simulator sends telemetry directly to IoT Hub instead of
# (or in addition to) the backend HTTP endpoint.
# Register each turbine as a device in your IoT Hub and paste the
# per-device connection strings below.
#
# Format: HostName=<hub>.azure-devices.net;DeviceId=<id>;SharedAccessKey=<key>

IOT_HUB_CONN_TURBINE_01=

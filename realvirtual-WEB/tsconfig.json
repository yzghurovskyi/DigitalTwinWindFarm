{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@rv/*": ["src/*"],
      "@rv-private/*": [
        "../realvirtual-WebViewer-Private~/src/*",
        "src/private-stubs/*"
      ],
      "three": ["./node_modules/@types/three"],
      "three/addons/*": ["./node_modules/@types/three/examples/jsm/*"],
      "three/*": ["./node_modules/@types/three/*"],
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "react-dom/client": ["./node_modules/@types/react-dom/client"],
      "@mui/material": ["./node_modules/@mui/material"],
      "@mui/material/*": ["./node_modules/@mui/material/*"],
      "@mui/icons-material": ["./node_modules/@mui/icons-material"],
      "@mui/icons-material/*": ["./node_modules/@mui/icons-material/*"]
    }
  },
  "include": ["src", "tests", "../realvirtual-WebViewer-Private~/src", "../realvirtual-WebViewer-Private~/projects"]
}

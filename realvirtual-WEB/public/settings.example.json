{
  "_comment": "Copy this file to settings.json to configure the WebViewer deployment.",

  "lockSettings": false,
  "lockedTabs": [],
  "hideWelcomeModal": false,
  "defaultModel": "models/demo.glb",

  "visual": {
    "lightingMode": "default",
    "orbitRotateSpeed": 1.0,
    "orbitPanSpeed": 1.0,
    "orbitZoomSpeed": 1.0,
    "orbitDampingFactor": 0.08
  },

  "physics": {
    "enabled": false,
    "gravity": 9.81,
    "friction": 1.5
  },

  "interface": {
    "activeType": "none",
    "autoConnect": false,
    "wsAddress": "localhost",
    "wsPort": 7000
  },

  "search": {
    "highlightEnabled": true,
    "nodesEnabled": true
  },

  "groups": {
    "excludedFromOverlay": [],
    "defaultHiddenGroups": []
  },

  "analytics": {
    "googleAnalyticsId": ""
  },

  "pluginConfig": {
    "_comment": "Per-plugin configuration. Missing keys fall back to built-in defaults.",
    "kiosk": {
      "_comment": "Kiosk Mode — opt-in auto-demo after idle timeout. Default is DISABLED (backwards-compatible for existing deployments). Trade-show / showroom installations set enabled: true.",
      "enabled": false,
      "idleTimeoutSeconds": 60,
      "hintIntervalSeconds": 15,
      "exitOnAnyInput": true,
      "pauseOnHidden": true,
      "respectReducedMotion": true,
      "cycleLimit": 0,
      "cameraAnimationTimeoutMs": 5000,
      "maxDwellMs": 60000,
      "maxConcurrentMessages": 5
    }
  }
}

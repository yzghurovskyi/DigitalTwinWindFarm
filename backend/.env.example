# Backend environment variables
# Copy this file to .env and fill in your values.

# Azure Digital Twins instance hostname (required for ADT writes)
# Example: myadt.api.weu.digitaltwins.azure.net
ADT_URL=

# Port the backend HTTP + WebSocket server listens on (default: 8080)
PORT=8080

# ADT twin ID of the farm root (default: WindFarm_01)
FARM_ID=WindFarm_01
